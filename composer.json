{
    "name": "php-tools/packages",
    "description": "Monorepo for php-tools/* Laravel and standalone PHP packages.",
    "license": "MIT",
    "authors": [
        {
            "name": "Jian.Ma",
            "email": "jian.ma@poper.co"
        }
    ],
    "require": {
        "php": "^8.4",
        "calebporzio/sushi": "^2.5",
        "composer/semver": "^3.4",
        "filament/filament": "^3.0 || ^4.0 || ^5.0",
        "filament/spatie-laravel-media-library-plugin": "^3.0 || ^4.0 || ^5.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "symfony/finder": "^7.0 || ^8.0",
        "ua-parser/uap-php": "^3.10"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/pest-plugin-testbench": "^4.1"
    },
    "replace": {
        "php-tools/comma-separated-values": "self.version",
        "php-tools/laravel-approval": "self.version",
        "php-tools/laravel-csv-parser": "self.version",
        "php-tools/laravel-database-task": "self.version",
        "php-tools/laravel-filament-approval": "self.version"
    },
    "autoload": {
        "psr-4": {
            "PHPTools\\": "src/PHPTools/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "App\\": "workbench/app/",
            "Database\\Factories\\": "workbench/database/factories/",
            "Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "PHPTools\\Approval\\ApprovalServiceProvider",
                "PHPTools\\LaravelCsvParser\\CsvParserPackageServiceProvider",
                "PHPTools\\LaravelDatabaseTask\\DatabaseTaskServiceProvider",
                "PHPTools\\LaravelFilamentApproval\\FilamentApprovalServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}