{
    "name": "php-tools/packages",
    "description": "Monorepo for php-tools/* Laravel and standalone PHP packages.",
    "license": "MIT",
    "authors": [
        {
            "name": "Jian.Ma",
            "email": "jian.ma@poper.co"
        }
    ],
    "require": {
        "php": "^8.4",
        "calebporzio/sushi": "^2.5",
        "composer/semver": "^3.4",
        "filament/filament": "^3.0 || ^4.0 || ^5.0",
        "filament/spatie-laravel-media-library-plugin": "^3.0 || ^4.0 || ^5.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/finder": "^7.4",
        "ua-parser/uap-php": "^3.10"
    },
    "replace": {
        "php-tools/comma-separated-values": "self.version",
        "php-tools/laravel-approval": "self.version",
        "php-tools/laravel-csv-parser": "self.version",
        "php-tools/laravel-database-task": "self.version",
        "php-tools/laravel-filament-approval": "self.version"
    },
    "require-dev": {
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "PHPTools\\": "src/PHPTools/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}