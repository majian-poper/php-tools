{
    "name": "php-tools/comma-separated-values",
    "description": "Csv file reader utility",
    "license": "MIT",
    "authors": [
        {
            "name": "Jian.Ma",
            "email": "jian.ma@poper.co"
        }
    ],
    "keywords": [
        "comma-separated-values",
        "csv"
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "PHPTools\\CommaSeparatedValues\\": ""
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}